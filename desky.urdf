<?xml version="1.0"?>
<!--
  desky 5-DOF arm — Unified Robot Description Format (URDF).

  Kinematic chain (yaw . roll . pitch . pitch . pitch):
      base_link  [joint1 yaw   Z]  link1
      link1      [joint2 roll  X]  link2
      link2      [joint3 pitch Y]  link3
      link3      [joint4 pitch Y]  link4
      link4      [joint5 pitch Y]  link5
      link5      [tool_joint fixed]  phone_mount   (end-effector)

  Units: meters and radians (URDF convention).

  NOTE: link lengths (joint <origin xyz>) are PLACEHOLDERS — measure the real
  arm and update them. The <dynamixel> block on each joint is a project-specific
  extension carrying the DYNAMIXEL id/model and the servo calibration used to
  map joint angle q -> servo angle (0..300 deg). Standard URDF tools ignore it;
  urdf_loader.py reads it.
-->
<robot name="desky">

  <!-- ===================== Links ===================== -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <geometry><box size="0.08 0.08 0.05"/></geometry>
    </visual>
  </link>

  <link name="link1">
    <visual>
      <origin xyz="0 0 0.015" rpy="0 0 0"/>
      <geometry><cylinder radius="0.03" length="0.03"/></geometry>
    </visual>
  </link>

  <link name="link2">
    <visual>
      <origin xyz="0 0 0.02" rpy="0 0 0"/>
      <geometry><box size="0.04 0.04 0.04"/></geometry>
    </visual>
  </link>

  <link name="link3">
    <visual>
      <origin xyz="0.06 0 0" rpy="0 0 0"/>
      <geometry><box size="0.12 0.03 0.03"/></geometry>
    </visual>
  </link>

  <link name="link4">
    <visual>
      <origin xyz="0.05 0 0" rpy="0 0 0"/>
      <geometry><box size="0.10 0.03 0.03"/></geometry>
    </visual>
  </link>

  <link name="link5">
    <visual>
      <origin xyz="0.04 0 0" rpy="0 0 0"/>
      <geometry><box size="0.08 0.02 0.02"/></geometry>
    </visual>
  </link>

  <!-- End-effector: the phone mount. -->
  <link name="phone_mount">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.01 0.07 0.14"/></geometry>
    </visual>
  </link>

  <!-- ===================== Joints ===================== -->
  <joint name="joint1" type="revolute">
    <parent link="base_link"/>
    <child link="link1"/>
    <origin xyz="0 0 0.05" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>              <!-- yaw -->
    <limit lower="-1.5708" upper="1.5708" effort="1.5" velocity="6.0"/>
    <dynamixel id="1" model="AX-18A" home_deg="150" direction="1"/>
  </joint>

  <joint name="joint2" type="revolute">
    <parent link="link1"/>
    <child link="link2"/>
    <origin xyz="0 0 0.03" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>              <!-- roll -->
    <limit lower="-1.5708" upper="1.5708" effort="1.5" velocity="6.0"/>
    <dynamixel id="2" model="AX-18A" home_deg="150" direction="1"/>
  </joint>

  <joint name="joint3" type="revolute">
    <parent link="link2"/>
    <child link="link3"/>
    <origin xyz="0 0 0.04" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>              <!-- pitch -->
    <limit lower="-1.5708" upper="1.5708" effort="1.5" velocity="6.0"/>
    <dynamixel id="3" model="AX-18A" home_deg="150" direction="1"/>
  </joint>

  <joint name="joint4" type="revolute">
    <parent link="link3"/>
    <child link="link4"/>
    <origin xyz="0.12 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>              <!-- pitch -->
    <limit lower="-1.5708" upper="1.5708" effort="1.5" velocity="6.0"/>
    <dynamixel id="4" model="AX-18A" home_deg="150" direction="1"/>
  </joint>

  <joint name="joint5" type="revolute">
    <parent link="link4"/>
    <child link="link5"/>
    <origin xyz="0.10 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>              <!-- pitch -->
    <limit lower="-1.5708" upper="1.5708" effort="1.5" velocity="6.0"/>
    <dynamixel id="5" model="AX-18A" home_deg="150" direction="1"/>
  </joint>

  <!-- Fixed transform from the last joint to the phone-mount frame. -->
  <joint name="tool_joint" type="fixed">
    <parent link="link5"/>
    <child link="phone_mount"/>
    <origin xyz="0.08 0 0" rpy="0 0 0"/>
  </joint>

</robot>
