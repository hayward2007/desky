<?xml version="1.0"?>
<!--
  desky 5-DOF arm — Unified Robot Description Format (URDF).

  Built from the Fusion 360 export in kinematics/configure/ (manifest.json +
  joints.json) and the STL meshes in kinematics/meshes/. Every joint origin
  below is the REAL relative transform between two occurrences' absolute
  world_transform (manifest.json), not a placeholder — computed as
  T_parent^-1 * T_child. bracket_f5/bracket_f6/link1/link2/guard/base_shell/
  end_effector are rigid (non-actuated) mesh links between the 5 actuated
  DYNAMIXEL stages, matching the physical build order:

      base_link -> base_shell -> dynamixel1 -> guard -> bracket_f5
                -> dynamixel2 -> bracket_f6 -> dynamixel3 -> link1
                -> dynamixel4 -> link2 -> dynamixel5 -> end_effector

  Each dynamixel body's own local Z axis (from its world_transform rotation)
  is its output-shaft axis, so every revolute <axis> below is (0 0 1) with
  the real orientation baked into that joint's <origin rpy>. Cross-checked
  against joints.json's 5 revolute joints: their axis directions (Y, X, X, Z,
  X relative to the bracket graph) match this file's per-dynamixel axes (Z,
  Y, X, X, X) as the same multiset, confirming both sources agree on the
  physical axes even though joints.json's bracket-level occurrence graph
  (via "PRT0006:1") doesn't reduce to a clean serial chain on its own.

  Units: meters and radians (mesh scale handles the mm -> m STL conversion).
  home_deg/direction are still PLACEHOLDERS (servo calibration, not
  geometry) — measure the real servo zero positions and update them; the
  <dynamixel> block is a project-specific extension read by urdf_loader.py,
  standard URDF tools ignore it.

  <limit> (per joint, in radians relative to q=0) is generated by
  kinematics/find_joint_limits.py, which sweeps each joint in MuJoCo (using
  the <collision> geoms below) and stops at the servo's physical 0-300 deg
  range or the first self-collision, whichever comes first. It does NOT
  depend on home_deg/direction, so it stays valid across recalibration —
  but the "physical range" half of that sweep does read home_deg/direction,
  so re-run the script after calibrating them for real.

  <inertial> on each dynamixel link is a PLACEHOLDER too (AX-18A's real ~55g
  mass, but a made-up box inertia) — MuJoCo's compiler rejects moving bodies
  with zero mass/inertia (unlike pybullet, which tolerates a missing
  <inertial>), so this is only here to satisfy that requirement for
  kinematics/mujoco_sim.py. It doesn't affect FK/IK (kinematics.kinematics.Arm
  never reads mass/inertia) or urdf_loader.py (ignores <inertial> entirely).
-->
<robot name="desky">

  <!-- This URDF only has <visual> meshes, no <collision> geoms. MuJoCo's
       URDF importer discards visual-only geoms unless told otherwise, which
       left the viewer window empty (0 geoms compiled). -->
  <mujoco>
    <compiler discardvisual="false"/>
  </mujoco>

  <!-- ===================== Links ===================== -->
  <link name="base_link"/>

  <link name="base_shell">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="../meshes/base.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="mat_base_stl"><color rgba="0.55 0.55 0.58 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="../meshes/base.stl" scale="0.001 0.001 0.001"/></geometry>
    </collision>
  </link>

  <link name="dynamixel1">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="../meshes/dynamixel.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="mat_dynamixel_stl"><color rgba="0.15 0.45 0.85 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="../meshes/dynamixel.stl" scale="0.001 0.001 0.001"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 -0.0135 0.00102" rpy="0 0 0"/>
      <mass value="0.055"/>
      <inertia ixx="1.9e-5" ixy="0" ixz="0" iyy="1.2e-5" iyz="0" izz="1.6e-5"/>
    </inertial>
  </link>

  <link name="guard">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="../meshes/gaurd.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="mat_gaurd_stl"><color rgba="0.90 0.55 0.10 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="../meshes/gaurd.stl" scale="0.001 0.001 0.001"/></geometry>
    </collision>
  </link>

  <link name="bracket_f5">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="../meshes/bracket_f5.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="mat_bracket_f5_stl"><color rgba="0.90 0.80 0.10 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="../meshes/bracket_f5.stl" scale="0.001 0.001 0.001"/></geometry>
    </collision>
  </link>

  <link name="dynamixel2">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="../meshes/dynamixel.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="mat_dynamixel_stl"><color rgba="0.15 0.45 0.85 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="../meshes/dynamixel.stl" scale="0.001 0.001 0.001"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 -0.0135 0.00102" rpy="0 0 0"/>
      <mass value="0.055"/>
      <inertia ixx="1.9e-5" ixy="0" ixz="0" iyy="1.2e-5" iyz="0" izz="1.6e-5"/>
    </inertial>
  </link>

  <link name="bracket_f6">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="../meshes/bracket_f6.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="mat_bracket_f6_stl"><color rgba="0.90 0.80 0.10 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="../meshes/bracket_f6.stl" scale="0.001 0.001 0.001"/></geometry>
    </collision>
  </link>

  <link name="dynamixel3">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="../meshes/dynamixel.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="mat_dynamixel_stl"><color rgba="0.15 0.45 0.85 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="../meshes/dynamixel.stl" scale="0.001 0.001 0.001"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 -0.0135 0.00102" rpy="0 0 0"/>
      <mass value="0.055"/>
      <inertia ixx="1.9e-5" ixy="0" ixz="0" iyy="1.2e-5" iyz="0" izz="1.6e-5"/>
    </inertial>
  </link>

  <link name="link1">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="../meshes/link.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="mat_link_stl"><color rgba="0.20 0.75 0.30 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="../meshes/link.stl" scale="0.001 0.001 0.001"/></geometry>
    </collision>
  </link>

  <link name="dynamixel4">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="../meshes/dynamixel.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="mat_dynamixel_stl"><color rgba="0.15 0.45 0.85 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="../meshes/dynamixel.stl" scale="0.001 0.001 0.001"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 -0.0135 0.00102" rpy="0 0 0"/>
      <mass value="0.055"/>
      <inertia ixx="1.9e-5" ixy="0" ixz="0" iyy="1.2e-5" iyz="0" izz="1.6e-5"/>
    </inertial>
  </link>

  <link name="link2">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="../meshes/link.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="mat_link_stl"><color rgba="0.20 0.75 0.30 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="../meshes/link.stl" scale="0.001 0.001 0.001"/></geometry>
    </collision>
  </link>

  <link name="dynamixel5">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="../meshes/dynamixel.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="mat_dynamixel_stl"><color rgba="0.15 0.45 0.85 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="../meshes/dynamixel.stl" scale="0.001 0.001 0.001"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 -0.0135 0.00102" rpy="0 0 0"/>
      <mass value="0.055"/>
      <inertia ixx="1.9e-5" ixy="0" ixz="0" iyy="1.2e-5" iyz="0" izz="1.6e-5"/>
    </inertial>
  </link>

  <!-- End-effector: the phone mount. -->
  <link name="end_effector">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="../meshes/end_effector.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="mat_end_effector_stl"><color rgba="0.85 0.15 0.15 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="../meshes/end_effector.stl" scale="0.001 0.001 0.001"/></geometry>
    </collision>
  </link>

  <!-- No visual: a bare marker frame at comp_4_1's own bounding-box centre. Needed
       because comp_4_1's Fusion world_transform is coincidentally identity (its
       mesh vertices are already absolute), which would otherwise make the
       end_effector link's own frame land at the assembly's design origin instead
       of anywhere near the actual phone mount. -->
  <link name="tool_tip"/>

  <!-- ===================== Joints ===================== -->
  <joint name="base_shell_joint" type="fixed">
    <parent link="base_link"/>
    <child link="base_shell"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <joint name="joint1" type="revolute">
    <parent link="base_shell"/>
    <child link="dynamixel1"/>
    <origin xyz="0 0 0.067" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>                          <!-- yaw : shaft along world Z -->
    <limit lower="-2.05949" upper="3.10669" effort="1.5" velocity="6.0"/>
    <dynamixel id="1" model="AX-18A" home_deg="180" direction="-1"/>
  </joint>

  <joint name="guard_joint" type="fixed">
    <parent link="dynamixel1"/>
    <child link="guard"/>
    <origin xyz="0 0 -0.067" rpy="0 0 0"/>
  </joint>

  <joint name="bracket_f5_joint" type="fixed">
    <parent link="guard"/>
    <child link="bracket_f5"/>
    <origin xyz="0 -0.016 0.12" rpy="3.14159 0 3.14159"/>
  </joint>

  <joint name="joint2" type="revolute">
    <parent link="bracket_f5"/>
    <child link="dynamixel2"/>
    <origin xyz="0 0.01525 0" rpy="1.5708 0 3.14159"/>
    <axis xyz="0 0 1"/>                          <!-- roll : shaft along world Y -->
    <limit lower="-1.53589" upper="1.53589" effort="1.5" velocity="6.0"/>
    <dynamixel id="2" model="AX-18A" home_deg="180" direction="-1"/>
  </joint>

  <joint name="bracket_f6_joint" type="fixed">
    <parent link="dynamixel2"/>
    <child link="bracket_f6"/>
    <origin xyz="0.019 -0.0145 0.016" rpy="0 -1.5708 1.5708"/>
  </joint>

  <joint name="joint3" type="revolute">
    <parent link="bracket_f6"/>
    <child link="dynamixel3"/>
    <origin xyz="-0.048 0.019 0.0145" rpy="1.5708 0 0"/>
    <axis xyz="0 0 1"/>                          <!-- pitch (shoulder) : shaft along world X -->
    <limit lower="-1.14319" upper="1.57952" effort="1.5" velocity="6.0"/>
    <dynamixel id="3" model="AX-18A" home_deg="180" direction="1"/>
  </joint>

  <joint name="link1_joint" type="fixed">
    <parent link="dynamixel3"/>
    <child link="link1"/>
    <origin xyz="0.03275 -0.149 0" rpy="0 -1.5708 -1.5708"/>
  </joint>

  <joint name="joint4" type="revolute">
    <parent link="link1"/>
    <child link="dynamixel4"/>
    <origin xyz="0 -0.03275 0.2665" rpy="1.5708 0 1.5708"/>
    <axis xyz="0 0 1"/>                          <!-- pitch (elbow) : shaft along world X -->
    <limit lower="-2.19039" upper="2.05949" effort="1.5" velocity="6.0"/>
    <dynamixel id="4" model="AX-18A" home_deg="180" direction="1"/>
  </joint>

  <joint name="link2_joint" type="fixed">
    <parent link="dynamixel4"/>
    <child link="link2"/>
    <origin xyz="0.03275 -0.149 0" rpy="0 -1.5708 -1.5708"/>
  </joint>

  <joint name="joint5" type="revolute">
    <parent link="link2"/>
    <child link="dynamixel5"/>
    <origin xyz="0 -0.03275 0.2665" rpy="1.5708 0 1.5708"/>
    <axis xyz="0 0 1"/>                          <!-- pitch (wrist) : shaft along world X -->
    <limit lower="-3.10669" upper="2.05949" effort="1.5" velocity="6.0"/>
    <dynamixel id="5" model="AX-18A" home_deg="180" direction="1"/>
  </joint>

  <joint name="end_effector_joint" type="fixed">
    <parent link="dynamixel5"/>
    <child link="end_effector"/>
    <origin xyz="0.03275 -0.384 0" rpy="0 -1.5708 -1.5708"/>
  </joint>

  <joint name="tool_tip_joint" type="fixed">
    <parent link="end_effector"/>
    <child link="tool_tip"/>
    <origin xyz="0 -0.03275 0.401065" rpy="0 0 0"/>
  </joint>

</robot>
