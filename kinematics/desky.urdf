<?xml version="1.0"?>
<!--
  desky 5-DOF arm — Unified Robot Description Format (URDF).

  Built from 5 identical DYNAMIXEL AX-18A servos. Each servo body is a box
  size = 0.047 (X) x 0.03 (Y) x 0.04 (Z). Its output shaft (rotation axis) is
  perpendicular to the TOP face (local Z), passing through the point that is
  centred in Y and 10 mm behind the front short edge:
      shaft point in box frame = (0.0135, 0, 0.02)
  So every dynamixel link's frame origin sits ON that shaft axis at the top
  face, and the box <visual> is offset by (-0.0135, 0, -0.02) from it. The
  joint <axis> is therefore local Z (0 0 1) for all five.

  Joint roles (base . tip), achieved by mounting each servo so its shaft points
  along the required world axis (via the joint origin rpy):
      joint1 yaw   -> shaft along world Z
      joint2 roll  -> shaft along world X
      joint3 pitch -> shaft along world Y  (shoulder)
      joint4 pitch -> shaft along world Y  (elbow)
      joint5 pitch -> shaft along world Y  (wrist)

  Units: meters and radians. Inter-servo spacings (joint origin xyz) are
  PLACEHOLDERS — measure the real arm and update them. The <dynamixel> block is
  a project-specific extension read by urdf_loader.py; standard tools ignore it.
-->
<robot name="desky">

  <!-- ===================== Links ===================== -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <geometry><box size="0.12 0.12 0.05"/></geometry>
    </visual>
  </link>

  <link name="dynamixel1">
    <visual>
      <origin xyz="-0.0135 0 -0.02" rpy="0 0 0"/>
      <geometry><box size="0.047 0.03 0.04"/></geometry>
    </visual>
  </link>

  <link name="dynamixel2">
    <visual>
      <origin xyz="-0.0135 0 -0.02" rpy="0 0 0"/>
      <geometry><box size="0.047 0.03 0.04"/></geometry>
    </visual>
  </link>

  <link name="dynamixel3">
    <visual>
      <origin xyz="-0.0135 0 -0.02" rpy="0 0 0"/>
      <geometry><box size="0.047 0.03 0.04"/></geometry>
    </visual>
  </link>

  <link name="dynamixel4">
    <visual>
      <origin xyz="-0.0135 0 -0.02" rpy="0 0 0"/>
      <geometry><box size="0.047 0.03 0.04"/></geometry>
    </visual>
  </link>

  <link name="dynamixel5">
    <visual>
      <origin xyz="-0.0135 0 -0.02" rpy="0 0 0"/>
      <geometry><box size="0.047 0.03 0.04"/></geometry>
    </visual>
  </link>

  <!-- End-effector: the phone mount. -->
  <link name="phone_mount">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.01 0.07 0.14"/></geometry>
    </visual>
  </link>

  <!-- ===================== Joints ===================== -->
  <joint name="joint1" type="revolute">
    <parent link="base_link"/>
    <child link="dynamixel1"/>
    <origin xyz="0 0 0.095" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>                          <!-- yaw : shaft along world Z -->
    <limit lower="-2.61799" upper="2.61799" effort="1.5" velocity="6.0"/>
    <dynamixel id="1" model="AX-18A" home_deg="180" direction="-1"/>
  </joint>

  <joint name="joint2" type="revolute">
    <parent link="dynamixel1"/>
    <child link="dynamixel2"/>
    <origin xyz="-0.01 0 0.026" rpy="0 1.5708 3.1416"/>
    <axis xyz="0 0 1"/>                          <!-- roll : shaft along world X -->
    <limit lower="-2.61799" upper="2.61799" effort="1.5" velocity="6.0"/>
    <dynamixel id="2" model="AX-18A" home_deg="180" direction="-1"/>
  </joint>

  <joint name="joint3" type="revolute">
    <parent link="dynamixel2"/>
    <child link="dynamixel3"/>
    <origin xyz="-0.0275 0.02 0.015" rpy="-1.5708 3.1416 0"/>
    <axis xyz="0 0 1"/>                          <!-- pitch (shoulder) : shaft along world Y -->
    <limit lower="-2.61799" upper="2.61799" effort="1.5" velocity="6.0"/>
    <dynamixel id="3" model="AX-18A" home_deg="180" direction="-1"/>
  </joint>

  <joint name="joint4" type="revolute">
    <parent link="dynamixel3"/>
    <child link="dynamixel4"/>
    <origin xyz="0.115 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>                          <!-- pitch (elbow) : shaft along world Y -->
    <limit lower="-2.61799" upper="2.61799" effort="1.5" velocity="6.0"/>
    <dynamixel id="4" model="AX-18A" home_deg="180" direction="-1"/>
  </joint>

  <joint name="joint5" type="revolute">
    <parent link="dynamixel4"/>
    <child link="dynamixel5"/>
    <origin xyz="0.115 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>                          <!-- pitch (wrist) : shaft along world Y -->
    <limit lower="-2.61799" upper="2.61799" effort="1.5" velocity="6.0"/>
    <dynamixel id="5" model="AX-18A" home_deg="180" direction="-1"/>
  </joint>

  <!-- Fixed transform from the last servo to the phone-mount frame. -->
  <joint name="tool_joint" type="fixed">
    <parent link="dynamixel5"/>
    <child link="phone_mount"/>
    <origin xyz="0.057 0 0" rpy="0 0 0"/>
  </joint>

</robot>
